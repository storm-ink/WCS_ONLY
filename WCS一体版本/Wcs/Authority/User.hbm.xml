<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Wcs" namespace="Wcs">
  <class name="User" table="`Users`" dynamic-update="true"  batch-size="500">
    <id name="Id" column="`Id`" type="Int32">
      <generator class="hilo">
        <param name="table">hilo_values</param>
        <param name="where">clazz='Users'</param>
        <param name="column">next_hi</param>
        <param name="max_lo">5</param>
      </generator>
    </id>

    <property name="UserName" column="`UserName`" type="String" length="50" not-null="true"  unique="true" />
    <property name="CreatedAt" column="`CreatedAt`" type="DateTime" not-null="true" />
    <property name="Password" column="`Password`" type="String" length="50" not-null="true" />
    <property name="RealName" column="`RealName`" type="String" length="50" not-null="true" />
    <property name="PasswordSalt" column="`PasswordSalt`" type="String" length="50" not-null="true" />
    <property name="IsBuiltIn" column="`IsBuiltIn`" type="Boolean" not-null="true" />
    <property name="Comments" column="`Comments`" type="String" length="255"/>
    <property name="Email" column="`Email`" type="String" length="255"/>

    <set name="Roles" table="`USER_ROLES`" batch-size="50">
      <key column="`UserId`" />
      <many-to-many class="Role" column="`RoleId`" />
    </set>

    <map name="Profile" table="`UserProfiles`" cascade="all-delete-orphan" batch-size="50">
      <key column="`UserId`" />
      <map-key column="`Key`" type="String" />
      <element column="`Value`" type="String" />
    </map>
  </class>
</hibernate-mapping>
