<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="true">

  <!-- 1. 定义日志输出目标 -->
  <targets>
    <!-- 输出到控制台，方便调试时直接查看 -->
    <target name="console" xsi:type="Console"
            layout="${longdate} [${level:uppercase=true}] ${logger} - ${message} ${exception}" />

    <!-- 输出到文件，方便异常发生后详细复盘 -->
    <target name="logfile" xsi:type="File"
            fileName="${basedir}/logs/nhibernate.log"
            layout="${longdate} [${level:uppercase=true}] ${logger} - ${message} ${exception}" />
  </targets>

  <!-- 2. 配置日志路由规则 -->
  <rules>
    <!-- 核心配置：专门捕获 NHibernate 框架的日志，并开启 Debug 级别 -->
    <logger name="NHibernate" minlevel="Debug" writeTo="console,logfile" />

    <!-- 如果想看 NHibernate 生成的具体 SQL 语句，可以额外加上这条（可选） -->
    <logger name="NHibernate.SQL" minlevel="Debug" writeTo="console,logfile" />
  </rules>

</nlog>