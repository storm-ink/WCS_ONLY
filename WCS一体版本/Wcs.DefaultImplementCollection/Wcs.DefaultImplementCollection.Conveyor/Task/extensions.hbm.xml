    <component class="Wcs.Framework.LocationInfo, Wcs.Framework" name="EndLocation">
      <property name="DeviceCode" type="String">
        <column name="`EndLocation_DeviceCode`" not-null="true" default="-1" />
      </property>
      <property name="UserCode" type="String">
        <column name="`EndLocation_UserCode`" not-null="true" default="-1" />
      </property>
      <property name="DeviceName" type="String">
        <column name="`EndLocation_DeviceName`" not-null="true" default="-1" />
      </property>
    </component>
    <property name="RouteId" type="Int32">
      <column name="`RouteId`" not-null="true" default="-1" />
    </property>
    <property name="AtPlcDBIndex" type="Int32" column="`AtPlcDBIndex`" not-null="false" />
