<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Wcs.DefaultImplementCollection.Conveyor" namespace="Wcs.Framework">
   <!--项目中使用到的逻辑动作在继承了 LogicMovement 后，为了将其进行持久化，必须在此处将其定义为 LogicMovement 的子类-->
  <subclass name="Wcs.DefaultImplementCollection.Conveyor.ConveyorTransferMovement" discriminator-value="ConveyorTransferMovement" extends="LogicMovement" dynamic-update="true">
  
  </subclass>
  
   <!--项目中使用到的逻辑动作在继承了 LogicMovement 后，为了将其进行持久化，必须在此处将其定义为 LogicMovement 的子类-->
