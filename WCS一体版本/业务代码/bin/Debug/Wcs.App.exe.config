<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<configSections>
		<section name="wcs-configuration" type="Wcs.Framework.Cfg.WcsConfigurationSectionHandler, Wcs.Framework"/>
		<section name="wcs-configuration-extend" type="Wcs.FrameworkExtend.Cfg.WcsConfigurationSectionHandler, Wcs.FrameworkExtend"/>
		<section name="webApiAssemblies" type="ZHQXC.WebApiAssembliesLoadElement, ZHQXC" />
		<section name="hibernate-configuration" type="NHibernate.Cfg.ConfigurationSectionHandler, NHibernate"/>
		<section name="backup-hibernate-configuration" type="NHibernate.Cfg.ConfigurationSectionHandler, NHibernate"/>
		<section name="deviceTrackingData-hibernate-configuration" type="NHibernate.Cfg.ConfigurationSectionHandler, NHibernate" />
		<section name="nlog" type="NLog.Config.ConfigSectionHandler, NLog"/>
	</configSections>

	<appSettings>
		<add key="nhibernate-logger" value="Wcs.NhLoggerFactory, Wcs" />
		<add key="LogWriteToFileBasePath" value="D:\WCSFileLogs"/>
		<add key="LogWriteToFile" value="D:\WCSFileLogs"/>
		<add key="LogWriteToFileOverTimeDelete" value="7"/>
		<add key="UserSessionTimeout" value="600000"/>
	</appSettings>
	<webApiAssemblies>
		<add assemblyName="ZHQXC.dll" />
	</webApiAssemblies>

	<wcs-configuration>
		<application>
			<startups xmlFile="系统配置/基本配置/startups.xml" />
		</application>
		<dataReceives>
			<receiver name="输送线解码器" type="Wcs.DefaultImplementCollection.Conveyor.ConveyorDataReceiverElement, Wcs.DefaultImplementCollection.Conveyor">
				<senderEncoding xmlFile="系统配置/输送线/立库CVdb1.xml" />
				<receiverEncoding xmlFile="系统配置/输送线/立库CVdb2.xml" />
			</receiver>
      <receiver name="条码扫描解码器" type="Wcs.DefaultImplementCollection.Scanner.ScanerDeviceDataReceiverElement, Wcs.DefaultImplementCollection.Scanner" />
      <receiver name="单货叉堆垛机解码器" type="Wcs.DefaultImplementCollection.Crane.DefaultCraneDataReceiverElement, Wcs.DefaultImplementCollection.Crane" >
				<telex type="Wcs.DefaultImplementCollection.Crane.CraneReportInfo, Wcs.DefaultImplementCollection.Crane" />
			</receiver>
      <receiver name="调度子系统AGV小车解码器" type="Wcs.DefaultImplementCollection.AGV.AGVDefaultSubSystemDataReceiverElement, Wcs.DefaultImplementCollection.AGV"></receiver>


      <receiver name="机械手解码器" type="Wcs.DefaultImplementCollection.Robot.DefaultRobotDeviceDataReceiverElement, Wcs.DefaultImplementCollection.Robot"/>

			<!--<receiver name="调度子系统CVCS解码器" type="ZHQXC.AGVDefaultSubSystemDataReceiverElement, ZHQXC"></receiver>-->


		</dataReceives>

		<devices>
			<conveyors type="Wcs.DefaultImplementCollection.Conveyor.ConveyorCollection, Wcs.DefaultImplementCollection.Conveyor">
				<conveyor name="立库CV" no="1" ip="192.168.6.2" port="2000"  dataReceiver="输送线解码器" receiveTimeout="3000" sendTimeout="3000" allowConcurrency="true" >
					<logicMovementSelector type="Wcs.DefaultImplementCollection.Conveyor.DefaultLogicMovementSelector, Wcs.DefaultImplementCollection.Conveyor" >
						<logicMovement type="Wcs.DefaultImplementCollection.Conveyor.ConveyorTransferMovement, Wcs.DefaultImplementCollection.Conveyor" />
					</logicMovementSelector>
					<equipmentActionScheduler type="Wcs.DefaultImplementCollection.Conveyor.ConveyorDeviceEquipmentActionScheduler, Wcs.DefaultImplementCollection.Conveyor">
						<filter type="ZHQXC.SpecialConveyorEquipmentActionFilter, ZHQXC" />
						<filter type="ZHQXC.ConveyorTaskFilter, ZHQXC" />
						<EquipmentActionSchedulerFilter type="ZHQXC.ConveyorTaskFilter, ZHQXC" />
					</equipmentActionScheduler>
				</conveyor>
			</conveyors>

      <scanners type="Wcs.DefaultImplementCollection.Scanner.ScanerDeviceCollection, Wcs.DefaultImplementCollection.Scanner">
        <scaner name="1502扫码器" no="1" ip="192.168.6.8" port="9004" bindingLocation="1503@立库CV" dataReceiver="条码扫描解码器" receiveTimeout="2147483647" />
      </scanners>


			<cranes type="Wcs.DefaultImplementCollection.Crane.CraneCollection, Wcs.DefaultImplementCollection.Crane">
				<crane name="C001" no="1" ip="192.168.6.23" port="2000" dataReceiver="单货叉堆垛机解码器" receiveTimeout="3000" sendTimeout="3000">
					<logicMovementSelector type="Wcs.DefaultImplementCollection.Crane.DefaultLogicMovementSelector, Wcs.DefaultImplementCollection.Crane" >
						<logicMovement type="Wcs.DefaultImplementCollection.Crane.CraneAutomaticTransferWithStepByStepMovement, Wcs.DefaultImplementCollection.Crane" />  
						<logicMovement type="Wcs.DefaultImplementCollection.Crane.CraneAutomaticTransferMovement, Wcs.DefaultImplementCollection.Crane" />
						<logicMovement type="Wcs.DefaultImplementCollection.Crane.CraneMoveMovement, Wcs.DefaultImplementCollection.Crane" />
					</logicMovementSelector>
					<equipmentActionScheduler type="Wcs.DefaultImplementCollection.Crane.DefaultCraneEquipmentActionScheduler, Wcs.DefaultImplementCollection.Crane">
						<!--<filter type="Wcs.DefaultImplementCollection.Crane.CraneForkDeepEquipmentActionSchedulerFilter, Wcs.DefaultImplementCollection.Crane" />-->
						<!--<filter type="Wcs.DefaultImplementCollection.Business.CraneUnloadEquipmentActionSchedulerFilter, Wcs.DefaultImplementCollection.Business" />-->
					</equipmentActionScheduler>
				</crane>
				
			</cranes>

      <robots type="Wcs.DefaultImplementCollection.Robot.RobotCollection, Wcs.DefaultImplementCollection.Robot">
        <robot name="主机械手" no="1" ip="192.168.6.9" port="60000" dataReceiver="机械手解码器" sendTimeOut="3000" receiveTimeout="10000">
          
          <!--<robot name="APM北机械手" no="1" ip="192.168.6.9" port="60000" dataReceiver="机械手解码器" sendTimeOut="3000" receiveTimeout="2147483647">-->
          <logicMovementSelector type="Wcs.Framework.DefaultLogicMovementSelector, Wcs.Framework" >
            <logicMovement type="Wcs.DefaultImplementCollection.Robot.RobotTransferByStepMovement, Wcs.DefaultImplementCollection.Robot" />
          </logicMovementSelector>
          <!--<equipmentActionScheduler type="Wcs.Framework.EquipmentActionScheduler, Wcs.Framework">
						<filter type="ESWIN2.RobotEquipmentActionFilter, ESWIN2" />
					</equipmentActionScheduler>-->
          <!--<equipmentActionToAddCommandPlugin type="ESWIN2.RobotTaskCommandHand, ESWIN2"/>-->
        </robot>
      </robots>
   
      <!--AGV相关-->
      <AGVSubSystems type="Wcs.DefaultImplementCollection.AGV.SinevaAGVCollection, Wcs.DefaultImplementCollection.AGV">
        <agv name="AGV调度系统" no="1" ip="192.168.3.1" port="5000" dataReceiver="调度子系统AGV小车解码器" receiveTimeout="3000" allowConcurrency="true" >
          <logicMovementSelector type="Wcs.DefaultImplementCollection.AGV.DefaultLogicMovementSelector, Wcs.DefaultImplementCollection.AGV" >

            <!-- <logicMovementSelector type="Wcs.Framework.DefaultLogicMovementSelector, Wcs.Framework" >
              -->

              <logicMovement type="Wcs.DefaultImplementCollection.AGV.SinevaAGVSubSystemLogicMovement, Wcs.DefaultImplementCollection.AGV" />
          </logicMovementSelector>
        </agv>
      </AGVSubSystems>

		</devices>

		<locations>
			<输送线 type="Wcs.DefaultImplementCollection.Conveyor.ConveyorLocationCollection, Wcs.DefaultImplementCollection.Conveyor" device="立库CV" xmlFile="系统配置/输送线/立库CV位置.xml" />
	
			<c001 xmlFile="系统配置/堆垛机/C001.xml" type="Wcs.DefaultImplementCollection.Crane.RackLocationCollection, Wcs.DefaultImplementCollection.Crane"/>
      <robot type="Wcs.DefaultImplementCollection.Robot.RobotLocationCollection, Wcs.DefaultImplementCollection.Robot" device="主机械手" xmlFile="系统配置/机械手/主机械手位置.xml" />
      <AGV调度系统站点 type="Wcs.DefaultImplementCollection.AGV.AGVSubSystemLocationCollection, Wcs.DefaultImplementCollection.AGV" device="AGV调度系统" xmlFile="系统配置/AGV/AGV站点.xml"/>
    </locations>

		<settings xmlFile="系统配置/基本配置/settings.xml" />
		<taskEventHandlers xmlFile="系统配置/基本配置/taskEventHandlers.xml" />
		<deviceWarningEventHandlers>
			<handler type="Wcs.Framework.DefaultDeviceWarningEventHandler, Wcs.Framework" />
		</deviceWarningEventHandlers>
		<equipmentFailureEventHandlers>
			<onAdded>
				<!--<handler type="Lutai.EquipmentFailureAddedEventHandler, Lutai" />-->
			</onAdded>
			<onRemoved>
				<!--<handler type="Lutai.EquipmentFailureRemovedEventHandler, Lutai" />-->
			</onRemoved>
		</equipmentFailureEventHandlers>
		<taskChouseEndLocationHandlers>
			<!--程序需要继承下面的抽象类-->
			<!--<handler type="Wcs.Framework.TaskChooseEndLocation, Wcs.Framework" />-->
			<!--<handler type="ZHQXC.TaskChooseEndLocation, ZHQXC" taskType="外型扫码" />-->
		</taskChouseEndLocationHandlers>
		<RouteSelectors>
			<!--程序需要继承下面的抽象类-->
			<!--<handler type="Wcs.Framework.RouteSelectors, Wcs.Framework" />-->
			<!--<handler type="ZHQXC.路径策略.AIFDRouteSelectors, ZHQXC" taskType="*"/>-->
		</RouteSelectors>

		<wmsTaskCompeletedExternalHandlers>
			<!--程序需要继承下面的抽象类-->
			<!--<handler type="Wcs.Framework.WMSTaskCompeletedExternalHandler, Wcs.Framework" />-->
			<!--<handler type="ZHQXC.WMSTaskCompeletedHandler, ZHQXC" taskType="入口到外形检测"/>
			<handler type="ZHQXC.WMSTaskCompeletedHandler_出库, ZHQXC" taskType="*"/>-->
		</wmsTaskCompeletedExternalHandlers>
		<taskRequestHandlers>
			<!--程序需要继承下面的抽象类-->
			<!--<handler type="Wcs.Framework.BaseTaskRequestHandler, Wcs.Framework" />-->
			<!--<handler type="ZHQXC.AutoClearOccupySingleTaskRequestHand, ZHQXC" taskType="*"/>-->
		</taskRequestHandlers>
		<equipmentActionSendPreHandlers>
			<!--程序需要继承下面的抽象类-->
			<!--<handler type="Wcs.Framework.BaseEquipmentActionSendPreHandler, Wcs.Framework" />-->
		</equipmentActionSendPreHandlers>
	</wcs-configuration>
	<wcs-configuration-extend>
		<!--预任务下发过滤器-->
		<preTaskSchedulerFilter>
			<!--程序需要继承下面的抽象类-->
			<!--<handler type="Wcs.FrameworkExtend.PreTaskSchedulerFilter, Wcs.FrameworkExtend" />-->
			<handler type="ZHQXC.PreTaskHand.SingleTaskDevicePreTaskSchedulerFilter, ZHQXC"/>
		</preTaskSchedulerFilter>

		<!--预任务取消处理程序（Source = WMS）-->
		<wmsTaskCancelledExternalHandlers>

		</wmsTaskCancelledExternalHandlers>

		<!--预任务完成处理程序（Source = WMS）-->
		<wmsTaskCompeletedExternalHandlers>
			<!--程序需要继承下面的抽象类-->
			<!--<handler type="Wcs.FrameworkExtend.WMSPreTaskCompeletedExternalHandler, Wcs.FrameworkExtend" />-->
			<!--<handler type="ZHQXC.SpecialAircraftEquipmentTaskCompelteHand, ZHQXC"/>-->
			<handler type="ZHQXC.PreTaskHand.TaskStateChangeReportWMSHand, ZHQXC" />
		</wmsTaskCompeletedExternalHandlers>

		<!--预任务完成处理程序（Source = Unknown）-->
		<taskRequestHandlers>
			<!--程序需要继承下面的抽象类-->
			<!--<handler type="Wcs.Framework.BaseTaskRequestHandler, Wcs.Framework" />-->
			<handler type="ZHQXC.AutoClearOccupySinglePreTaskRequestHand, ZHQXC" taskType="*"/>
		</taskRequestHandlers>
	</wcs-configuration-extend>

	<hibernate-configuration  xmlns="urn:nhibernate-configuration-2.2" >

		<session-factory name="wcs">
			<property name="connection.driver_class">NHibernate.Driver.SqlClientDriver</property>
			<property name="connection.connection_string">Data Source=.;Initial Catalog=wcs;User Id=sa;Password=Sineva@123;</property>
			<property name="dialect">NHibernate.Dialect.MsSql2005Dialect</property>
			<property name="adonet.batch_size">50</property>
			<property name="query.substitutions">true 1, false 0</property>
			<property name="prepare_sql">false</property>
			<property name="show_sql">false</property>

			<!--
      如果需要开启NHibernate的缓存功能，取消下面的注释行，并安装 SysCache2 3.2.0.4000，具体方法如下：
      打开程序包管理器控制台，输入 install-package NHibernate.Caches.SysCache2 -version 3.2.0.4000
      回车后安装即可
      -->

			<!--
      <property name="cache.use_second_level_cache">true</property>
      <property name="cache.use_query_cache">true</property>
      <property name="cache.provider_class">NHibernate.Caches.SysCache2.SysCacheProvider, NHibernate.Caches.SysCache2</property>
      -->


			<mapping assembly="Wcs" />
			<mapping assembly="Wcs.Framework" />
			<mapping assembly="Wcs.FrameworkExtend" />
			<mapping assembly="Wcs.DefaultImplementCollection.Conveyor" />
			<mapping assembly="Wcs.DefaultImplementCollection.Crane" />
      <mapping assembly="Wcs.DefaultImplementCollection.Scanner" />
      <mapping assembly="Wcs.DefaultImplementCollection.Robot" />
      <mapping assembly="Wcs.DefaultImplementCollection.AGV" />

      <mapping assembly="ZHQXC" />
      

      <!--如果当前项目包含 nhibernate 的映射文件，应将当前项目的程序集名加到此处-->

		</session-factory>
	</hibernate-configuration>

	<backup-hibernate-configuration>
		<session-factory name="wcs" xmlns="urn:nhibernate-configuration-2.2" >
			<property name="connection.driver_class">NHibernate.Driver.SqlClientDriver</property>
			<property name="connection.connection_string">Data Source=.;Initial Catalog=wcs_bak;User Id=sa;Password=Sineva@123;</property>
			<property name="dialect">NHibernate.Dialect.MsSql2005Dialect</property>
			<property name="adonet.batch_size">50</property>
			<property name="query.substitutions">true 1, false 0</property>
			<property name="prepare_sql">true</property>
			<property name="show_sql">false</property>
			<mapping assembly="Wcs" />
			<mapping assembly="Wcs.Framework" />
			<mapping assembly="Wcs.FrameworkExtend" />
			<mapping assembly="Wcs.DefaultImplementCollection.Conveyor" />
			<mapping assembly="Wcs.DefaultImplementCollection.Crane" />
      <mapping assembly="Wcs.DefaultImplementCollection.Scanner" />
      <mapping assembly="Wcs.DefaultImplementCollection.Robot" />
      <mapping assembly="Wcs.DefaultImplementCollection.AGV" />

      <mapping assembly="ZHQXC" />

			<!--如果当前项目包含 nhibernate 的映射文件，应将当前项目的程序集名加到此处-->
			<!--<mapping assembly="sample" />-->
		</session-factory>
	</backup-hibernate-configuration>

	<deviceTrackingData-hibernate-configuration>
		<session-factory name="wcs" xmlns="urn:nhibernate-configuration-2.2">
			<property name="connection.driver_class">NHibernate.Driver.SqlClientDriver</property>
			<!--默认使用 Wcs 数据直接存储，但在正试部署后应该使用单独的数据库存储-->
			<property name="connection.connection_string">Data Source=.;Initial Catalog=wcs;User Id=sa;Password=Sineva@123;</property>
			<property name="dialect">NHibernate.Dialect.MsSql2005Dialect</property>
			<property name="adonet.batch_size">50</property>
			<property name="query.substitutions">true 1, false 0</property>
			<property name="prepare_sql">true</property>
			<property name="show_sql">false</property>
			<mapping assembly="Wcs" />
			<mapping assembly="Wcs.Framework" />
			<mapping assembly="Wcs.FrameworkExtend" />
			<mapping assembly="Wcs.DefaultImplementCollection.Conveyor" />
			<mapping assembly="Wcs.DefaultImplementCollection.Crane" />
      <mapping assembly="Wcs.DefaultImplementCollection.Scanner" />
      <mapping assembly="Wcs.DefaultImplementCollection.Robot" />

      <mapping assembly="ZHQXC" />

			<!--如果当前项目包含 nhibernate 的映射文件，应将当前项目的程序集名加到此处-->
			<!--<mapping assembly="sample" />-->
		</session-factory>
	</deviceTrackingData-hibernate-configuration>

	<nlog throwExceptions="false">
		<targets async="true">
			<target name="database" type="Database" connectionString="Data Source=.;Initial Catalog=wcs_logs;User Id=sa;Password=Sineva@123;Enlist=False"
					  commandText="INSERT INTO [dbo].[Logs] ([LongDate],[Level],[ThreadId] ,[Logger],[Message],[Exception],[Sender],[MachineName],[ProcessName],[UserName],[EquipmentTaskId],[TaskCode])
              VALUES 
              (@LongDate ,@Level ,@ThreadId ,@Logger ,@Message ,@Exception,@Sender,@MachineName, @ProcessName,@UserName,@EquipmentTaskId,@TaskCode)">
				<parameter name="@LongDate" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff}" />
				<parameter name="@Level" layout="${level}" />
				<parameter name="@MachineName" layout="${machineName}" />
				<parameter name="@ProcessName" layout="${processname}" />
				<parameter name="@ProcessId" layout="${processid}" />
				<parameter name="@ThreadId" layout="${threadid}" />
				<parameter name="@Logger" layout="${logger}" />
				<parameter name="@Message" layout="${message}" />
				<parameter name="@Exception" layout="${exception:format=tostring}" />
				<parameter name="@Sender" layout="${event-context:sender}" />
				<parameter name="@UserName" layout="${event-context:userName}" />
				<parameter name="@EquipmentTaskId" layout="${event-context:equipmentTaskId}" />
				<parameter name="@TaskCode" layout="${event-context:taskCode}" />
			</target>
		</targets>
		<rules>

			<!--如果需要输出NHibernate的SQL或其它日志，请修改下面两个logger 的minLevel（Off表示关闭日志输出功能）-->
			<logger name="NHibernate.SQL" writeTo="database" final="true" minlevel="Off" />
			<logger name="NHibernate*" writeTo="database" final="true" minlevel="Off" />

			<logger name="*" minlevel="Trace" writeTo="database" />

		</rules>
	</nlog>
	<!--如果报DLL版本不对，可以使用下面的方法解决-->
	<runtime>
		<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
			<dependentAssembly>
				<assemblyIdentity name="NHibernate" publicKeyToken="aa95f207798dfdb4" culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-3.3.1.4000" newVersion="3.3.1.4000" />
			</dependentAssembly>
		</assemblyBinding>
	</runtime>

</configuration>