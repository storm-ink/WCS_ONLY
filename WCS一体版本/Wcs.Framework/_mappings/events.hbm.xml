  <subclass name="Wcs.Framework.Events.RequestStatusChangedEvent" discriminator-value="RequestStatusChangedEvent" extends="Wcs.Framework.EventBus.IEvent">
    <property name="Id" column="RequestStatusChangedEvent_Id" type="Int32"  />
    <property name="Status" column="RequestStatusChangedEvent_Status" type="RequestStatus"  />
  </subclass>
</hibernate-mapping>