  </subclass>
  
  <subclass name="Wcs.Framework.Events.TaskFinishedEvent" discriminator-value="TaskFinishedEvent" extends="Wcs.Framework.EventBus.IEvent">
    <property name="Id" column="TaskFinishedEvent_Id" type="Int32"  />
