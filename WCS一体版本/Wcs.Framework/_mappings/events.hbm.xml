    <property name="Status" column="TaskFinishedEvent_Status" type="TaskStatus"  />
    <property name="FinishedAt" column="`FinishedAt`" type="DateTime" />
    <property name="TaskType" column="TaskFinishedEvent_TaskType" type="String" length="25"  />
    <property name="BizType" column="TaskFinishedEvent_BizType" type="Wcs.Framework.TaskBizType, Wcs.Framework" />
    <property name="Source" column="`TaskFinishedEvent_Source`" type="Wcs.Framework.TaskSource, Wcs.Framework"/>
  </subclass>
  
  <subclass name="Wcs.Framework.Events.RequestAddedEvent" discriminator-value="RequestAddedEvent" extends="Wcs.Framework.EventBus.IEvent">
    <many-to-one class="Request" name="Request" column="`ReqeustId`" not-found="ignore" not-null="false" lazy="false"/>
  </subclass>
  
  <subclass name="Wcs.Framework.Events.RequestArchivedEvent" discriminator-value="RequestArchivedEvent" extends="Wcs.Framework.EventBus.IEvent">
    <property name="Id" column="RequestArchivedEvent_Id" type="Int32"  />
