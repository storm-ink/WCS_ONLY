    <property name="Status" column="LogicMovementStatusChangedEvent_Status" type="LogicMovementStatus" />
  </subclass>

  <subclass name="Wcs.Framework.Events.TaskArchivedEvent" discriminator-value="TaskArchivedEvent" extends="Wcs.Framework.EventBus.IEvent">
    <property name="Id" column="TaskArchivedEvent_Id" type="Int32"  />
