<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Wcs.Framework" namespace="Wcs.Framework">
  <class name="Wcs.Framework.EventBus.IEvent" table="Events" batch-size="500">
    <id name="EventKey" column="`EventKey`" type="String">
      <generator class="assigned" />
    </id>
    <discriminator column="`discriminator`" type="String" not-null="true"/>
    <property name="Preservable" column="`Preservable`" type="Boolean" not-null="true" />
    <property name="CreatedAt" column="`CreatedAt`" type="DateTime" not-null="true" />
  </class>

  <subclass name="Wcs.Framework.Events.EquipmentActionStatusChangedEvent" discriminator-value="EquipmentActionStatusChangedEvent" extends="Wcs.Framework.EventBus.IEvent">
    <property name="TaskId" column="EquipmentActionStatusChangedEvent_TaskId" type="Int32"  />
    <property name="MovementId" column="EquipmentActionStatusChangedEvent_MovementId" type="Int32"  />
    <property name="Id" column="EquipmentActionStatusChangedEvent_Id" type="Int32"  />
    <property name="Status" column="EquipmentActionStatusChangedEvent_Status" type="EquipmentActionStatus"  />
  </subclass>

  <subclass name="Wcs.Framework.Events.LogicMovementStatusChangedEvent" discriminator-value="LogicMovementStatusChangedEvent" extends="Wcs.Framework.EventBus.IEvent">
