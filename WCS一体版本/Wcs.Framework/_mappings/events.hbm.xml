  </subclass>

  <subclass name="Wcs.Framework.Events.TaskCurrentLocationChangedEvent" discriminator-value="TaskCurrentLocationChangedEvent" extends="Wcs.Framework.EventBus.IEvent">
    <property name="Id" column="TaskArchivedEvent_Id" type="Int32"  />
