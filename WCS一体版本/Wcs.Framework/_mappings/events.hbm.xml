	  <property column="`TaskCurrentLocationChangedEventCurrentLocation_UnifiedCode`" name="UnifiedCode" type="String"/>
      <property column="`TaskCurrentLocationChangedEventCurrentLocation_DeviceCode`" name="DeviceCode" type="String"/>
      <property column="`TaskCurrentLocationChangedEventCurrentLocation_UserCode`" name="UserCode" type="String"/>
      <property column="`TaskCurrentLocationChangedEventCurrentLocation_DeviceName`" name="DeviceName" type="String"/>
    </component>
  </subclass>

  <subclass name="Wcs.Framework.Events.TaskPriorityChangedEvent" discriminator-value="TaskPriorityChangedEvent" extends="Wcs.Framework.EventBus.IEvent">
    <property name="Id" column="TaskPriorityChangedEvent_Id" type="Int32"  />
    <property name="TaskCode" column="TaskPriorityChangedEvent_TaskCode" type="String" length="50"  />
    <property name="Priority" column="TaskPriorityChangedEvent_Priority" type="Int32"  />
  </subclass>

  <subclass name="Wcs.Framework.Events.TaskStatusChangedEvent" discriminator-value="TaskStatusChangedEvent" extends="Wcs.Framework.EventBus.IEvent">
    <property name="Id" column="TaskStatusChangedEvent_Id" type="Int32"  />
    <property name="TaskCode" column="TaskPriorityChangedEvent_TaskCode" type="String" length="50"  />
    <property name="Status" column="TaskStatusChangedEvent_Status" type="TaskStatus"  />
    <property name="TaskType" column="TaskStatusChangedEvent_TaskType" type="String" length="25"  />
    <property name="BizType" column="TaskStatusChangedEvent_BizType" type="Wcs.Framework.TaskBizType, Wcs.Framework" />
