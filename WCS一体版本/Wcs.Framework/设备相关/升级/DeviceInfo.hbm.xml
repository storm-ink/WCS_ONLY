      create view WarningRecordView
      as
      SELECT Id,Code,Name,Category,Device,DeviceType,BeginingAt,EndingAt,FinishedAt,UserName,Repaired,IsFault,Description,Result,Reason,TotalMilliseconds
      FROM WarningRecords
    </create>
    <drop>
      drop view WarningRecordView
    </drop>
  </database-object>-->
</hibernate-mapping>
