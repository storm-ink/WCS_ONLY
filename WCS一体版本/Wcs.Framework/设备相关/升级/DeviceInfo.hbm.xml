<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Wcs.Framework" namespace="Wcs.Framework">
  <class name="DeviceErrorType" table="DeviceErrorType" batch-size="500" dynamic-update="true">
    <cache usage="read-write"/>
    <id name="Id" column="`Id`" type="Int32"/>
	<property name="AlarmCategory" column="`AlarmCategory`" type="Int32" not-null="true" />
    <property name="DeviceType" column="`DeviceType`" type="String" not-null="true" />
    <property name="DeviceErrorCode" column="`DeviceErrorCode`" type="string" length="10" not-null="true" />
    <property name="ErrorName" column="`ErrorName`" type="String" not-null="true" />
	<property name="Description" column="`Description`" type="String" not-null="true" />
    <property name="Levle" column="`Levle`" type="Int16" not-null="true" />
    <property name="Solution" type="String" length="1000" column="`Solution`"/>
    <property name="IsFault" type="Boolean" column="`IsFault`"/>
  </class>
  <class name="DeviceState" table="DeviceState" batch-size="500" dynamic-update="true">
    <cache usage="read-write"/>
    <id name="Id" column="`Id`" type="Int32">
      <generator class="hilo">
        <param name="table">hilo_values</param>
        <param name="where">clazz='DeviceState'</param>
        <param name="column">next_hi</param>
        <param name="max_lo">5</param>
      </generator>
    </id>
    <property name="DeviceName" column="`DeviceName`" type="String" length="10" not-null="true" />
    <property name="Device" column="`Device`" type="String" length="20" not-null="true" />
    <property name="State" column="`State`" type="Wcs.Framework.DeviceStatus, Wcs.Framework" not-null="true" />
    <property name="Description" column="`Description`" type="String" length="1000" not-null="true" />
    <property name="TaskLock" column="`TaskLock`" type="Int32" not-null="true" />
  </class>
  <!--<database-object>
