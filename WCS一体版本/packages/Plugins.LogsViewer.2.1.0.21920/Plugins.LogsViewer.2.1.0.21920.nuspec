<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>Plugins.LogsViewer</id>
    <version>2.1.0.21920</version>
    <title>Wcs日志查看器</title>
    <authors>合肥井松自动化科技有限公司</authors>
    <owners>合肥井松自动化科技有限公司</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>提供一个简单的查询界面，用于查询Wcs日志信息，并支持查看同期设备数据、归档日志数据。</description>
    <dependencies>
      <dependency id="Wcs" version="2.1.0.21908" />
    </dependencies>
  </metadata>
</package>