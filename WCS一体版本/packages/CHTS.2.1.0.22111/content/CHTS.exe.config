<?xml version="1.0"?>
<configuration>
  <appSettings>
    <add key="双伸位" value="false"/>
  </appSettings>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="BasicHttpBinding_ICraneService" />
            </basicHttpBinding>
        </bindings>
        <client>
            <endpoint address="http://localhost:9991/CraneService" binding="basicHttpBinding"
                bindingConfiguration="BasicHttpBinding_ICraneService" contract="CraneService.ICraneService"
                name="BasicHttpBinding_ICraneService" />
        </client>
    </system.serviceModel>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0"/></startup></configuration>
